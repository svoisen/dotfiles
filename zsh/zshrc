# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# homebrew (macOS only)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -x "/opt/homebrew/bin/brew" ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x "/usr/local/bin/brew" ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# oh-my-zsh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
export ZSH="$HOME/.oh-my-zsh"
plugins=(tmux vi-mode common-aliases git zsh-eza)
source "$ZSH/oh-my-zsh.sh"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# path
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
path=("$HOME/bin" "$HOME/go/bin" "$HOME/.juliaup/bin" $path)
export PATH

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# environment variables
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
export EDITOR='nvim'
export VISUAL="$EDITOR"
export BAT_THEME='catppuccin-macchiato'

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# aliases
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
alias zshrc="$EDITOR ~/.zshrc"
alias vimrc="$EDITOR ~/.vimrc"
alias c="clear"
command -v fzf &> /dev/null && alias vo='nvim -o `fzf`'
alias gfix='nvim `git diff --name-only | uniq`'
command -v bat &> /dev/null && alias cat="bat"
command -v python3 &> /dev/null && ! command -v python &> /dev/null && alias python="python3"
command -v pip3 &> /dev/null && ! command -v pip &> /dev/null && alias pip="pip3"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# fzf
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if command -v fzf &> /dev/null && fzf --zsh &> /dev/null; then
  source <(fzf --zsh)
elif [ -f ~/.fzf.zsh ]; then
  source ~/.fzf.zsh
fi

export FZF_DEFAULT_OPTS="
--ansi
--layout=default
--info=inline
--height=50%
--multi
--border
--preview-window=right:50%
--preview-window=sharp
--preview-window=cycle
--preview '([[ -f {} ]] && (bat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {})) || ([[ -d {} ]] && (tree -C {} | less)) || echo {} 2> /dev/null | head -200'
--bind 'ctrl-e:execute(nvim {} < /dev/tty > /dev/tty 2>&1)' > selected
--bind 'ctrl-v:execute(code {+})'"

if command -v rg &> /dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --follow -g "!{.git,node_modules}/*" 2> /dev/null'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# nvm
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
export NVM_DIR="$HOME/.nvm"
# Homebrew (macOS)
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
# Standard install (Linux)
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# netlify
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
test -f "$HOME/Library/Preferences/netlify/helper/path.zsh.inc" && source "$HOME/Library/Preferences/netlify/helper/path.zsh.inc"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# local API keys
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$HOME/.anthropic-api-key" ] && source "$HOME/.anthropic-api-key"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# spaceship prompt
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "/opt/homebrew/opt/spaceship/spaceship.zsh" ]; then
  source "/opt/homebrew/opt/spaceship/spaceship.zsh"
elif [ -f "$HOME/.oh-my-zsh/custom/themes/spaceship-prompt/spaceship.zsh" ]; then
  source "$HOME/.oh-my-zsh/custom/themes/spaceship-prompt/spaceship.zsh"
fi
